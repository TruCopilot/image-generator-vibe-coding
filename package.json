{
  "name": "@trucopilot/image-generator-vibe-coding",
  "version": "1.3.0",
  "description": "MCP server for AI image generation via OpenRouter (default), Runware, or Google Gemini. Works with Claude Code, Cursor, Windsurf, and any MCP-compatible tool.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "image-generator-vibe-coding": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TruCopilot/image-generator-vibe-coding.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test:runware": "node scripts/test-runware.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "image-generation",
    "openrouter",
    "runware",
    "gemini",
    "ai",
    "vibe-coding",
    "claude-code",
    "cursor",
    "windsurf"
  ],
  "author": "TruCopilot (https://trucopilot.com)",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
